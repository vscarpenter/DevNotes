{
  "name": "devnotes",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "clean": "rm -rf dist dev-dist out",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "deploy": "npm run build && npm run deploy:s3 && npm run deploy:invalidate",
    "deploy:s3": "aws s3 sync dist/ s3://notes.vinny.dev --delete --cache-control \"public, max-age=31536000, immutable\" --exclude \"*.html\" --exclude \"*.json\" && aws s3 sync dist/ s3://notes.vinny.dev --delete --cache-control \"public, max-age=0, must-revalidate\" --include \"*.html\" --include \"*.json\"",
    "deploy:invalidate": "aws cloudfront create-invalidation --distribution-id E219UQK7YM96PZ --paths \"/*\""
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.42.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/prismjs": "^1.26.6",
    "@types/react-window": "^1.8.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "dexie": "^3.2.7",
    "fuse.js": "^7.3.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.294.0",
    "mermaid": "^11.15.0",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^1.8.11",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "unified": "^11.0.5",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/jszip": "^3.4.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.12.4",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "jest-axe": "^10.0.0",
    "jsdom": "^23.2.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "terser": "^5.47.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^1.6.1",
    "workbox-window": "^7.4.1"
  }
}
